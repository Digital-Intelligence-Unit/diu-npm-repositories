{
    "extends": "@adonisjs/tsconfig/tsconfig.package.json",
    "compilerOptions": {
      "rootDir": "./",
      "outDir": "./build",
      "emitDecoratorMetadata": true,
      "useDefineForClassFields": false, // For model exports

      // Custom ignores
      "strictPropertyInitialization": false,
      "noUnusedParameters": false,
      "noUnusedLocals": false
    }
}